[
    {
        "id": "CO_001",
        "type": "coding",
        "title": "LRU Cache",
        "function_name": "LRUCache",
        "question": "Design a data structure that follows the constraints of a Least Recently Used (LRU) cache. Implement the LRUCache class:\n- `LRUCache(int capacity)` - Initialize the LRU cache with positive size capacity\n- `int get(int key)` - Return the value of the key if it exists, otherwise return -1\n- `void put(int key, int value)` - Update the value of the key if it exists, otherwise add the key-value pair to the cache. If the number of keys exceeds capacity, evict the least recently used key.\nBoth get and put must operate in O(1) average time complexity.\n**Example:**\n```Input: [\"LRUCache\", \"put\", \"put\", \"get\", \"put\", \"get\", \"put\", \"get\", \"get\", \"get\"]\n       [[2], [1, 1], [2, 2], [1], [3, 3], [2], [4, 4], [1], [3], [4]]\nOutput: [null, null, null, 1, null, -1, null, -1, 3, 4]```\n**Constraints:**\n- 1 <= capacity <= 3000\n- 0 <= key <= 10^4\n- 0 <= value <= 10^5\n- At most 2 * 10^5 operations",
        "test_cases": [
            {
                "input": {"operations": ["LRUCache", "put", "put", "get", "put", "get", "put", "get", "get", "get"], "arguments": [[2], [1, 1], [2, 2], [1], [3, 3], [2], [4, 4], [1], [3], [4]]},
                "output": [null, null, null, 1, null, -1, null, -1, 3, 4]
            },
            {
                "input": {"operations": ["LRUCache", "put", "get", "put", "get", "get"], "arguments": [[1], [1, 1], [1], [2, 2], [1], [2]]},
                "output": [null, null, 1, null, -1, 2]
            },
            {
                "input": {"operations": ["LRUCache", "put", "put", "put", "put", "get", "get", "get"], "arguments": [[2], [1, 1], [2, 2], [1, 10], [3, 3], [1], [2], [3]]},
                "output": [null, null, null, null, null, 10, -1, 3]
            },
            {
                "input": {"operations": ["LRUCache", "put", "put", "get", "put", "get", "get", "get"], "arguments": [[2], [1, 1], [2, 2], [1], [3, 3], [1], [2], [3]]},
                "output": [null, null, null, 1, null, 1, -1, 3]
            },
            {
                "input": {"operations": ["LRUCache", "put", "get", "get", "put", "get"], "arguments": [[2], [0, 0], [0], [1], [1, 0], [1]]},
                "output": [null, null, 0, -1, null, 0]
            },
            {
                "input": {"operations": ["LRUCache", "put", "put", "put", "get", "put", "get", "get", "get"], "arguments": [[3], [1, 1], [2, 2], [3, 3], [1], [4, 4], [2], [3], [4]]},
                "output": [null, null, null, null, 1, null, -1, 3, 4]
            }
        ]
    },
    {
        "id": "CO_002",
        "type": "coding",
        "title": "Word Break",
        "function_name": "wordBreak",
        "question": "Given a string `s` and a dictionary of words `wordDict`, return `true` if `s` can be segmented into a space-separated sequence of dictionary words, or `false` otherwise.\n**Example:**\n```Input: s = \"leetcode\", wordDict = [\"leet\", \"code\"]\nOutput: true\n\nInput: s = \"applepenapple\", wordDict = [\"apple\", \"pen\"]\nOutput: true\n\nInput: s = \"catsandog\", wordDict = [\"cat\", \"cats\", \"and\", \"sand\", \"dog\"]\nOutput: false```\n**Constraints:**\n- 1 <= s.length <= 300\n- 1 <= wordDict.length <= 1000\n- 1 <= wordDict[i].length <= 20\n- s and wordDict[i] consist of only lowercase English letters",
        "test_cases": [
            {
                "input": {"s": "leetcode", "wordDict": ["leet", "code"]},
                "output": true
            },
            {
                "input": {"s": "applepenapple", "wordDict": ["apple", "pen"]},
                "output": true
            },
            {
                "input": {"s": "catsandog", "wordDict": ["cat", "cats", "and", "sand", "dog"]},
                "output": false
            },
            {
                "input": {"s": "a", "wordDict": ["a"]},
                "output": true
            },
            {
                "input": {"s": "aaaaaaa", "wordDict": ["aaaa", "aaa"]},
                "output": true
            },
            {
                "input": {"s": "cats", "wordDict": ["cat", "cats", "and", "sand", "dog"]},
                "output": true
            },
            {
                "input": {"s": "", "wordDict": ["a"]},
                "output": true
            },
            {
                "input": {"s": "aaaaab", "wordDict": ["a", "aa", "aaa", "aaaa"]},
                "output": false
            },
            {
                "input": {"s": "cars", "wordDict": ["car", "ca", "rs"]},
                "output": true
            },
            {
                "input": {"s": "pineapplepenapple", "wordDict": ["apple", "pen", "applepen", "pine", "pineapple"]},
                "output": true
            }
        ]
    },
    {
        "id": "CO_003",
        "type": "coding",
        "title": "Merge Intervals",
        "function_name": "mergeIntervals",
        "question": "Given an array of intervals `[start, end]`, merge all overlapping intervals and return the result sorted by start time.\n**Example:**\n```Input: intervals = [[1, 3], [2, 6], [8, 10], [15, 18]]\nOutput: [[1, 6], [8, 10], [15, 18]]```\n**Constraints:**\n- 0 <= intervals.length <= 10^4\n- -10^9 <= start <= end <= 10^9",
        "test_cases": [
            {
                "input": {"intervals": [[1, 3], [2, 6], [8, 10], [15, 18]]},
                "output": [[1, 6], [8, 10], [15, 18]]
            },
            {
                "input": {"intervals": [[1, 4], [4, 5]]},
                "output": [[1, 5]]
            },
            {
                "input": {"intervals": []},
                "output": []
            },
            {
                "input": {"intervals": [[5, 7]]},
                "output": [[5, 7]]
            },
            {
                "input": {"intervals": [[1, 4], [2, 3]]},
                "output": [[1, 4]]
            },
            {
                "input": {"intervals": [[1, 4], [0, 2], [3, 5]]},
                "output": [[0, 5]]
            },
            {
                "input": {"intervals": [[-10, -1], [-5, 0], [1, 2]]},
                "output": [[-10, 0], [1, 2]]
            }
        ]
    },
    {
